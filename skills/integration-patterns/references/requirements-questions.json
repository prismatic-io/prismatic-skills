{
  "start": "systems",
  "questions": {
    "systems": {
      "id": "systems",
      "text": "What systems are you connecting? (e.g., 'Salesforce to Slack', 'Webhook to Database')",
      "type": "text",
      "allow_inference": true,
      "inference_sources": [],
      "next": ["trigger_type"]
    },
    "trigger_type": {
      "id": "trigger_type",
      "text": "What triggers this integration? (Note: pollingTrigger is not supported in CNI - use scheduled or webhook instead)",
      "type": "choice",
      "choices": ["webhook", "scheduled", "manual", "ai agent"],
      "allow_inference": true,
      "inference_sources": ["systems"],
      "next": ["scheduled_details", "data_flow"]
    },
    "scheduled_details": {
      "id": "scheduled_details",
      "text": "How often should the integration run?",
      "type": "choice",
      "choices": [
        "Every minute",
        "Every 5 minutes",
        "Every 15 minutes",
        "Hourly",
        "Daily",
        "Weekly",
        "Custom cron expression"
      ],
      "condition": {
        "question": "trigger_type",
        "answer": "scheduled"
      },
      "next": ["data_flow"]
    },
    "data_flow": {
      "id": "data_flow",
      "text": "What data flows between systems? Describe the records, fields, or operations involved.",
      "type": "text",
      "allow_inference": true,
      "inference_sources": ["systems"],
      "next": ["source_system"]
    },
    "source_system": {
      "id": "source_system",
      "text": "What is the SOURCE system name? (e.g., 'Salesforce', 'Shopify', 'Custom API')",
      "type": "text",
      "allow_inference": true,
      "inference_sources": ["systems", "data_flow"],
      "next": ["source_component"]
    },
    "source_component": {
      "id": "source_component",
      "text": "Let me search for existing Prismatic components for the source system.",
      "type": "dynamic_choice",
      "command": ["npx", "tsx", "scripts/integrations/search-components.ts", "{source_system}"],
      "choice_key": "key",
      "choice_label": "label",
      "store_full_object": true,
      "allow_skip": true,
      "next": ["source_webhook_details", "source_connection_type"]
    },
    "source_connection_type": {
      "id": "source_connection_type",
      "text": "Which connection/authentication type should be used for the source component?",
      "type": "dynamic_choice",
      "command": ["npx", "tsx", "scripts/integrations/extract-connections.ts", "{source_component.connections}"],
      "choice_key": "key",
      "choice_label": "label",
      "store_full_object": true,
      "allow_skip": true,
      "skip_if_empty": true,
      "condition": {
        "question": "source_component",
        "answer_is": "not_empty"
      },
      "next": ["source_provide_credentials"]
    },
    "source_provide_credentials": {
      "id": "source_provide_credentials",
      "text": "Would you like to provide OAuth/API credentials for the source system now?\n\nIf you provide them now, they'll be written to the .env file and OAuth will work immediately after deployment.",
      "type": "choice",
      "choices": [
        "Yes, I'll provide credentials now (Recommended)",
        "Skip for now (add manually to .env later)"
      ],
      "condition": {
        "question": "source_connection_type",
        "answer_is": "not_empty"
      },
      "next": ["source_webhook_auth", "source_connection"]
    },
    "source_webhook_details": {
      "id": "source_webhook_details",
      "text": "No component found for the source system. What is the incoming webhook payload format?",
      "type": "choice",
      "choices": ["JSON", "XML", "Form Data", "Plain Text"],
      "allow_inference": true,
      "inference_sources": ["source_system"],
      "condition": {
        "question": "source_component",
        "answer_is": "empty"
      },
      "next": ["source_webhook_auth"]
    },
    "source_webhook_auth": {
      "id": "source_webhook_auth",
      "text": "Does the incoming webhook require authentication/verification?",
      "type": "choice",
      "choices": [
        "No authentication",
        "API Key in header",
        "HMAC Signature verification",
        "Basic Auth"
      ],
      "allow_inference": true,
      "inference_sources": ["source_system"],
      "next": ["source_connection"]
    },
    "source_connection": {
      "id": "source_connection",
      "text": "Which connection type for the source system?",
      "type": "choice",
      "choices": [
        "Use existing integration-agnostic connection",
        "Create new connection in integration",
        "No connection needed (public API)"
      ],
      "next": ["source_connection_existing", "destination_system"]
    },
    "source_connection_existing": {
      "id": "source_connection_existing",
      "text": "Select an existing connection:",
      "type": "dynamic_choice",
      "command": ["npx", "tsx", "scripts/shared/search-connections.ts", "{source_system}"],
      "choice_key": "stableKey",
      "choice_label": "label",
      "store_full_object": true,
      "condition": {
        "question": "source_connection",
        "answer": "Use existing integration-agnostic connection"
      },
      "next": ["destination_system"]
    },
    "destination_system": {
      "id": "destination_system",
      "text": "What is the DESTINATION system name? (e.g., 'Slack', 'PostgreSQL', 'S3')",
      "type": "text",
      "allow_inference": true,
      "inference_sources": ["systems", "data_flow"],
      "next": ["destination_component"]
    },
    "destination_component": {
      "id": "destination_component",
      "text": "Let me search for existing Prismatic components for the destination system.",
      "type": "dynamic_choice",
      "command": ["npx", "tsx", "scripts/integrations/search-components.ts", "{destination_system}"],
      "choice_key": "key",
      "choice_label": "label",
      "store_full_object": true,
      "allow_skip": true,
      "next": ["destination_connection_type"]
    },
    "destination_connection_type": {
      "id": "destination_connection_type",
      "text": "Which connection/authentication type should be used for the destination component?",
      "type": "dynamic_choice",
      "command": ["npx", "tsx", "scripts/integrations/extract-connections.ts", "{destination_component.connections}"],
      "choice_key": "key",
      "choice_label": "label",
      "store_full_object": true,
      "allow_skip": true,
      "skip_if_empty": true,
      "condition": {
        "question": "destination_component",
        "answer_is": "not_empty"
      },
      "next": ["destination_provide_credentials"]
    },
    "destination_provide_credentials": {
      "id": "destination_provide_credentials",
      "text": "Would you like to provide OAuth/API credentials for the destination system now?\n\nIf you provide them now, they'll be written to the .env file and OAuth will work immediately after deployment.",
      "type": "choice",
      "choices": [
        "Yes, I'll provide credentials now (Recommended)",
        "Skip for now (add manually to .env later)"
      ],
      "condition": {
        "question": "destination_connection_type",
        "answer_is": "not_empty"
      },
      "next": ["destination_connection"]
    },
    "destination_connection": {
      "id": "destination_connection",
      "text": "Which connection type for the destination system?",
      "type": "choice",
      "choices": [
        "Use existing integration-agnostic connection",
        "Create new connection in integration",
        "No connection needed (public API)"
      ],
      "next": ["destination_connection_existing", "transformations"]
    },
    "destination_connection_existing": {
      "id": "destination_connection_existing",
      "text": "Select an existing connection:",
      "type": "dynamic_choice",
      "command": ["npx", "tsx", "scripts/shared/search-connections.ts", "{destination_system}"],
      "choice_key": "stableKey",
      "choice_label": "label",
      "store_full_object": true,
      "condition": {
        "question": "destination_connection",
        "answer": "Use existing integration-agnostic connection"
      },
      "next": ["transformations"]
    },
    "transformations": {
      "id": "transformations",
      "text": "Are any data transformations needed? (e.g., field mapping, filtering, enrichment)",
      "type": "text",
      "allow_inference": true,
      "inference_sources": ["systems", "data_flow"],
      "next": ["error_handling"]
    },
    "error_handling": {
      "id": "error_handling",
      "text": "What error handling is needed?",
      "type": "multi_choice",
      "choices": [
        "Automatic retry on failure",
        "Send notification on error (email/Slack)",
        "Log errors for review",
        "Stop execution on error",
        "Continue despite errors"
      ],
      "next": ["retry_config", "additional_requirements"]
    },
    "retry_config": {
      "id": "retry_config",
      "text": "How many times should failed operations retry?",
      "type": "choice",
      "choices": ["0 (no retries)", "1", "3", "5", "10"],
      "condition": {
        "question": "error_handling",
        "answer": "Automatic retry on failure"
      },
      "next": ["additional_requirements"]
    },
    "additional_requirements": {
      "id": "additional_requirements",
      "text": "Any additional requirements or constraints? (e.g., rate limits, special business logic, compliance needs)",
      "type": "text",
      "allow_skip": true,
      "next": []
    }
  }
}
